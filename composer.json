{
	"description": "The CodeIgniter framework",
	"name": "codeigniter/framework",
	"type": "project",
	"homepage": "https://codeigniter.com",
	"license": "MIT",
	"require": {
		"php": ">=7.4",
		"firebase/php-jwt": "^7.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.5.50"
	},
	"config": {
		"vendor-dir": "vendor"
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:unit": "phpunit --testsuite 'Unit Tests' --testsuite 'Library Tests'",
		"test:api": "phpunit --testsuite 'API Tests'",
		"test:results": "phpunit --log-junit tests/results/junit-unit.xml && php tests/generate_results.php > automated_tests.md"
	}
}
